<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.financeiro.poupeja.controller.VisualizacaoCategoriaController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" maxWidth="300">
        <Hyperlink text="← Voltar para Login" onAction="#voltarParaLogin" />
    </HBox>

    <Button text="Criar Categoria" onAction="#cadastrarCategoria" prefWidth="300" prefHeight="40">
        <VBox.margin>
            <Insets top="10.0" />
        </VBox.margin>
    </Button>
</VBox>
