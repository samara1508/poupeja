<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.financeiro.poupeja.controller.DashboardController" style="-fx-background-color: #F5F5F5;">
    <content>
        <BorderPane style="-fx-background-color: #F5F5F5;">
            <top>
                <VBox alignment="TOP_CENTER" spacing="15">
                    <padding>
                        <Insets top="25" right="30" bottom="15" left="30"/>
                    </padding>

					<HBox alignment="CENTER_LEFT" maxWidth="300">
					    <Hyperlink text="← Voltar para Menu" onAction="#voltarMenu" />
					</HBox>

                    <Label text="Dashboard" style="-fx-font-weight: bold;">
                        <font>
                            <Font size="24"/>
                        </font>
                    </Label>

                    <HBox alignment="CENTER" spacing="12" style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E0E0E0;" maxWidth="800">
                        <Label text="Data Início:" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                        <DatePicker fx:id="dpDataInicio" prefWidth="130" prefHeight="30"/>
                        
                        <Label text="Data Fim:" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                        <DatePicker fx:id="dpDataFim" prefWidth="130" prefHeight="30"/>

                        <Button text="Aplicar Filtro" onAction="#aplicarFiltros" prefHeight="30" prefWidth="110" style="-fx-background-color: #002244; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        <Button text="Atualizar ↻" onAction="#atualizarDados" prefHeight="30" prefWidth="100" style="-fx-background-color: #e0e0e0; -fx-text-fill: #333; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </top>

            <center>
                <VBox spacing="20" alignment="TOP_CENTER">
                    <padding>
                        <Insets right="30" left="30" bottom="30"/>
                    </padding>

                    <HBox alignment="CENTER" spacing="20" maxWidth="800">
                        <!-- Card: Receitas vs Despesas -->
                        <VBox spacing="8" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #DDD; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 1);" prefWidth="380">
                            <Label text="Receitas x Despesas no período" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #777;"/>
                            <Separator style="-fx-padding: 2 0 2 0;"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Total Recebido:" style="-fx-font-size: 14px; -fx-text-fill: #555;"/>
                                <Label fx:id="lblTotalReceitas" text="R$ 0,00" style="-fx-font-size: 16px; -fx-text-fill: #2e7d32; -fx-font-weight: bold;"/>
                            </HBox>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Total Gasto:" style="-fx-font-size: 14px; -fx-text-fill: #555;"/>
                                <Label fx:id="lblTotalDespesas" text="R$ 0,00" style="-fx-font-size: 16px; -fx-text-fill: #c62828; -fx-font-weight: bold;"/>
                            </HBox>
                        </VBox>

                        <!-- Card: Previsto vs Realizado (Metas) -->
                        <VBox spacing="8" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #DDD; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 1);" prefWidth="380">
                            <Label text="Previsto x Realizado no período" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #777;"/>
                            <Separator style="-fx-padding: 2 0 2 0;"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Gasto Realizado:" style="-fx-font-size: 14px; -fx-text-fill: #555;"/>
                                <Label fx:id="lblTotalGastoMeta" text="R$ 0,00" style="-fx-font-size: 16px; -fx-text-fill: #1565c0; -fx-font-weight: bold;"/>
                            </HBox>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Meta Acumulada:" style="-fx-font-size: 14px; -fx-text-fill: #555;"/>
                                <Label fx:id="lblTotalMetaCategorias" text="R$ 0,00" style="-fx-font-size: 16px; -fx-text-fill: #555; -fx-font-weight: bold;"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- Seção do Gráfico -->
                    <VBox alignment="CENTER" maxWidth="800" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #DDD; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 1);" VBox.vgrow="ALWAYS">
                        <Label text="Gastos por Categoria x Meta" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #333;">
                            <VBox.margin>
                                <Insets bottom="10"/>
                            </VBox.margin>
                        </Label>
                        <BarChart fx:id="chartGastos" prefHeight="350" legendVisible="false">
                            <xAxis>
                                <CategoryAxis fx:id="xAxisCategorias" label="Categorias" style="-fx-font-weight: bold;"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis fx:id="yAxisValores" label="Valor (R$)" style="-fx-font-weight: bold;"/>
                            </yAxis>
                        </BarChart>
                    </VBox>
                </VBox>
            </center>
        </BorderPane>
    </content>
</ScrollPane>
