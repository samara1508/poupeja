<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.financeiro.poupeja.controller.TotaisFormaPagamentoController"
            style="-fx-background-color: #F5F5F5;">

    <top>
        <VBox alignment="TOP_CENTER" spacing="20">
            <padding>
                <Insets top="30" right="30" bottom="20" left="30"/>
            </padding>

            <HBox alignment="CENTER_LEFT" maxWidth="300">
                <Hyperlink text="← Voltar para Menu" onAction="#voltarMenu" />
            </HBox>

            <Label text="Totais por Forma de Pagamento">
                <font>
                    <Font size="22"/>
                </font>
            </Label>
        </VBox>
    </top>

    <center>
        <VBox spacing="15" alignment="TOP_CENTER">
            <padding>
                <Insets right="30" left="30" bottom="30"/>
            </padding>

            <TableView fx:id="tabelaRelatorio" VBox.vgrow="ALWAYS" prefHeight="350">
                <columns>
                    <TableColumn fx:id="colFormaPagamento" text="Forma de Pagamento" prefWidth="250" style="-fx-alignment: CENTER_LEFT;"/>
                    <TableColumn fx:id="colValor" text="Valor" prefWidth="150" style="-fx-alignment: CENTER_RIGHT;"/>
                    <TableColumn fx:id="colQuantidade" text="Número de Lançamentos" prefWidth="180" style="-fx-alignment: CENTER;"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER" spacing="15">
                <Button fx:id="btnAnterior"
                        text="← Anterior"
                        onAction="#paginaAnterior"/>
                <Label fx:id="lblPagina" text="Página 1 de 1" style="-fx-text-fill: #555; -fx-font-size: 13px;"/>
                <Button fx:id="btnProximo"
                        text="Próxima →"
                        onAction="#proximaPagina"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
