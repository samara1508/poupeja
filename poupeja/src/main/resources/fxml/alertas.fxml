<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.financeiro.poupeja.controller.AlertaController"
            style="-fx-background-color: #F5F5F5;">

    <top>
        <VBox alignment="TOP_CENTER" spacing="20">
            <padding>
                <Insets top="30" right="30" bottom="15" left="30"/>
            </padding>

			<HBox alignment="CENTER_LEFT" maxWidth="300">
			    <Hyperlink text="← Voltar para Menu" onAction="#voltarMenu" />
			</HBox>

            <Label text="Alertas">
                <font>
                    <Font size="22"/>
                </font>
            </Label>

            <HBox alignment="CENTER" spacing="10">
                <TextField fx:id="txtBusca"
                           promptText="Pesquisar por descrição..."
                           prefWidth="220"
                           prefHeight="35"/>
                <Button text="Buscar"
                        onAction="#filtrar"
                        prefHeight="35"/>
                <Button text="Limpar"
                        onAction="#limparFiltro"
                        prefHeight="35"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="15" alignment="TOP_CENTER">
            <padding>
                <Insets right="30" left="30" bottom="20"/>
            </padding>

            <TableView fx:id="tabelaAlertas" VBox.vgrow="ALWAYS" prefHeight="250">
                <columns>
                    <TableColumn fx:id="colDescricao" text="Descrição" prefWidth="150" style="-fx-alignment: CENTER_LEFT;"/>
                    <TableColumn fx:id="colLancamento" text="Lançamento" prefWidth="150" style="-fx-alignment: CENTER_LEFT;"/>
                    <TableColumn fx:id="colDiasAntes" text="Dias Antecedentes" prefWidth="90" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colEmail" text="E-mail de Destino" prefWidth="130" style="-fx-alignment: CENTER_LEFT;"/>
                    <TableColumn fx:id="colDataCriacao" text="Data Criação" prefWidth="90" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colUltimaExecucao" text="Última Execução" prefWidth="90" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="90" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colAcoes" text="Ações" prefWidth="80" style="-fx-alignment: CENTER;"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER" spacing="15">
                <Button fx:id="btnAnterior"
                        text="← Anterior"
                        onAction="#paginaAnterior"/>
                <Label fx:id="lblPagina" text="Página 1 de 1" style="-fx-text-fill: #555; -fx-font-size: 13px;"/>
                <Button fx:id="btnProximo"
                        text="Próxima →"
                        onAction="#proximaPagina"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <VBox alignment="CENTER">
            <padding>
                <Insets top="10" right="30" bottom="30" left="30"/>
            </padding>
            <Button text="Criar Novo Alerta"
                    prefHeight="45"
                    maxWidth="400"
                    onAction="#criarNovoAlerta"/>
        </VBox>
    </bottom>

</BorderPane>
